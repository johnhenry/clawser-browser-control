{
  "manifest_version": 2,
  "name": "Clawser Browser Control",
  "version": "0.1.0",
  "description": "Gives the Clawser agent real browser control: tabs, screenshots, DOM, input, monitoring.",

  "applications": {
    "gecko": {
      "id": "clawser@clawser.dev",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "tabs",
    "activeTab",
    "webRequest",
    "cookies",
    "storage",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["*://localhost/*", "*://127.0.0.1/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
